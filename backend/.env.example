# Copy this file to .env in this directory (backend/.env) and fill in values.

# Required for registration / Pinata
WALLET_PRIVATE_KEY=<YOUR_WALLET_PRIVATE_KEY>
PINATA_JWT=<YOUR_PINATA_JWT>

# Optional: Storacha (decentralized storage) – set both to enable Storacha in the app
# 1. Install CLI: npm install -g @storacha/cli
# 2. Create account/space: storacha login <email>, storacha space create <name>, storacha space use <space-did>
# 3. Create key: storacha key create
#    → Copy the private key (starts with Mg...) into STORACHA_KEY below
#    → Copy the DID (did:key:z6Mk...) from the same output – you need it for step 4
# 4. Create proof: storacha delegation create <did-from-step-3> --base64
#    → Paste the entire base64 output into STORACHA_PROOF below (one line, no quotes)
# See https://docs.storacha.network/how-to/upload/
# STORACHA_KEY=
# STORACHA_PROOF=

# Other optional vars (see backend/src/.env.example for full list)
# RPC_PROVIDER_URL=
# PORT=5000
